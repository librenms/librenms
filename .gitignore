*.pyc
*.swp
Thumbs.db
config.php
html/css/custom/*
html/images/custom/*
html/images/custommap/*
includes/custom/*
junk
nbproject
patches
!/lib/yaml
/vendor
/node_modules
npm-debug.log
yarn-error.log
composer.phar
composer.plugins.json
_ide_helper.php
_ide_helper_models.php
resources/views/menu/custom.blade.php
resources/js/vue-i18n-locales.generated.js
*.code-workspace

