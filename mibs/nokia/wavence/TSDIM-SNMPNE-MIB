::= { tsdimSnmpNEMibObject 46 }

opticsIMIfQueueEntry OBJECT-TYPE
  SYNTAX OpticsIMIfQueueEntry
  MAX-ACCESS not-accessible
  STATUS current
  DESCRIPTION
