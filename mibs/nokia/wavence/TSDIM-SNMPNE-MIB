opticsIMNeFrameSizeMode OBJECT-TYPE
  SYNTAX      INTEGER {
    native (0),
    layer1 (1),
    layer2 (2)
  }
  MAX-ACCESS  read-write
  STATUS      current
  DESCRIPTION
    "opticsIMNeFrameSizeMode specifies 'on per NE basis' the type of ingress
     policer, egress shaper and Performance Monitoring counters to be applied
     to all NE ports:
