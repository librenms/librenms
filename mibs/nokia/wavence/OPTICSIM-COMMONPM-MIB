opticsimCommonPmMCConf  OBJECT IDENTIFIER ::= { tsdimBasicMC 10 }
opticsimCommonPmMCCompl OBJECT IDENTIFIER ::= { opticsimCommonPmMCConf 1 }
opticsimCommonPmMCGroup OBJECT IDENTIFIER ::= { opticsimCommonPmMCConf 2 }

opticsimCommonPmMc MODULE-COMPLIANCE
    STATUS current
    DESCRIPTION
        "This module compliance describes a set of objects required for
         TSD-IM SNMP Agent implementation.
         These objects are defined inside opticsimCommonPmMib"

    MODULE -- opticsimCommonPmMib



GROUP opticsIMFilterHistoryDataGroup
    DESCRIPTION
        "This group describes the objects needed for the History Data
         filtering criteria management."

GROUP opticsIMTimeGroup
    DESCRIPTION
        "This group describes the objects needed for time definitions."

::= { opticsimCommonPmMCCompl 1 }

-- Units of Conformance

opticsIMFilterHistoryDataGroup OBJECT-GROUP
    OBJECTS { opticsIMFilterHDStartByOS,
              opticsIMFilterHDBeginTimeInterval,
              opticsIMFilterHDEndTimeInterval,
              opticsIMFilterHDGranularityPeriod,
              opticsIMFilterHDRowStatus}
    STATUS current
    DESCRIPTION
        "This group  describes the objects needed for History Data
         filtering criteria."
::= { opticsimCommonPmMCGroup 1 }

opticsIMTimeGroup OBJECT-GROUP
    OBJECTS { pmMaintRetrievingTime,
              pmMaintLastDiscontinuityTimeStamp }
    STATUS current
    DESCRIPTION
        "This group  describes the objects needed for time definition."
::= { opticsimCommonPmMCGroup 2 }

END
