equipmentCombinerFunction    OBJECT-TYPE
     SYNTAX INTEGER { disabled    (1),
                      enabled     (2)  }
     MAX-ACCESS     read-write
     STATUS            current
     DESCRIPTION
         " This object specifies whether the Combiner function is currently allowed to work or no on this radio equipment."
::= { opticsIMEquipmentExtenEntry 4 }

-- begin SNMPIDL-499
equipmentInputVoltage OBJECT-TYPE
     SYNTAX Integer32
     MAX-ACCESS     read-only
     STATUS            current
     DESCRIPTION
         " This object reports the value of instantaneous voltage applied to the equipment. The unit of measure is NE dependent and will be defined on own external specification."
::= { opticsIMEquipmentExtenEntry 5 }

equipmentInputCurrent OBJECT-TYPE
     SYNTAX Integer32
     MAX-ACCESS     read-only
     STATUS            current
     DESCRIPTION
         " This object reports the value of the instantaneous electric current flowing through the equipment. The unit of measure is NE dependent and will be defined on own external specification."
::= { opticsIMEquipmentExtenEntry 6 }

equipmentPowerConsumption OBJECT-TYPE
     SYNTAX Integer32
     MAX-ACCESS     read-only
     STATUS            current
     DESCRIPTION
         " This object reports the value of the instantaneous power consumed by the equipment. The unit of measure is NE dependent and will be defined on own external specification"
::= { opticsIMEquipmentExtenEntry 7 }
-- end SNMPIDL-499

-- begin SNMPIDL-500
equipmentInputVoltageThreshold OBJECT-TYPE
     SYNTAX Integer32
     MAX-ACCESS     read-write
     STATUS            current
     DESCRIPTION
         " This object defines the value of the threshold for the instantaneous voltage used to raise the lowInputVoltage alarm. The unit of measure is NE dependent and will be defined on own external specification
In case of '0' value the lowInputVoltage alarm is never raised (feature implicitly disabled)."
::= { opticsIMEquipmentExtenEntry 8 }
-- end SNMPIDL-500

