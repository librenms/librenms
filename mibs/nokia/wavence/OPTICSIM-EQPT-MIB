OpticsIMEquipmentExtenEntry ::= SEQUENCE {
  equipmentTemperature          Integer32,
  equipmentTrsObjectConnected      Integer32,
  equipmentCombinerImplemented  TruthValue,
  equipmentCombinerFunction    INTEGER,
-- begin SNMPIDL-499
   equipmentInputVoltage         Integer32,
   equipmentInputCurrent         Integer32,
   equipmentPowerConsumption    Integer32,
-- end SNMPIDL-499
-- begin SNMPIDL-500
   equipmentInputVoltageThreshold Integer32
-- end SNMPIDL-500
}

equipmentTemperature  OBJECT-TYPE
  SYNTAX              Integer32
  MAX-ACCESS          read-only
  STATUS              current
  DESCRIPTION
    "This object reports the temperature of the equipment expressed in Celsius
     degrees "
::= { opticsIMEquipmentExtenEntry 1 }

equipmentTrsObjectConnected      OBJECT-TYPE
  SYNTAX              Integer32
  MAX-ACCESS          read-write
  STATUS              current
  DESCRIPTION
    "This object contains the information related to the transmission resource (in term of slot and port
     where the equipment is connected to) referenced for this equipment resource (equipmentPosition)."
