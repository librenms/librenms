BSS-RCP-MIB DEFINITIONS ::= BEGIN

IMPORTS
   enterprises, Counter, TimeTicks, Gauge   FROM RFC1155-SMI
   sysUpTime, DisplayString                 FROM RFC1213-MIB
   OBJECT-TYPE                              FROM RFC-1212
   TRAP-TYPE                                FROM RFC-1215;

bss OBJECT IDENTIFIER ::= { enterprises 3967 }

--
-- Divisions of Bosch Sicherheitssysteme Engineering GmbH
--

rcp OBJECT IDENTIFIER ::= { bss 1 }



sys OBJECT IDENTIFIER ::= { rcp 1 }



identification OBJECT IDENTIFIER ::= { sys 1 }

unit-name OBJECT-TYPE
SYNTAX DisplayString
ACCESS read-write
STATUS optional
DESCRIPTION 
"WRITE: set unit name (max 31 unicode character + null delimiter)
 READ: read the unit name
 "
::= {identification 1}

unit-id OBJECT-TYPE
SYNTAX DisplayString
ACCESS read-write
STATUS optional
DESCRIPTION 
"WRITE: set unit ID (max 31 unicode character + null delimiter)
 READ: read the unit ID
 "
::= {identification 2}


camnameTable OBJECT-TYPE
SYNTAX  SEQUENCE OF CamnameEntry
ACCESS  not-accessible
STATUS  mandatory
DESCRIPTION ""
::= { identification 3 }

camnameEntry OBJECT-TYPE
SYNTAX  CamnameEntry
ACCESS  not-accessible
STATUS  mandatory
DESCRIPTION ""
INDEX   { camname }
::= { camnameTable 1 }

camname OBJECT-TYPE
SYNTAX DisplayString
ACCESS read-write
STATUS optional
DESCRIPTION 
"WRITE: Deprecated! Use CONF_CAMNAME_LINES instead. (max 31 unicode character + null delimiter)
 READ: Deprecated! Use CONF_CAMNAME_LINES instead.
 "
::= {camnameEntry 1}

CamnameEntry ::= SEQUENCE {
camname DisplayString
}

hardware-version OBJECT-TYPE
SYNTAX DisplayString
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: read the hardware version
 "
::= {identification 4}

software-version OBJECT-TYPE
SYNTAX DisplayString
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: read the software version
 "
::= {identification 5}

serial-number OBJECT-TYPE
SYNTAX OCTET STRING
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: returns the serial number of the device. The representation of this serial number is binary octets
 "
::= {identification 6}

manufacturer-name OBJECT-TYPE
SYNTAX DisplayString
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: returns the manufacturer name
 "
::= {identification 7}



time OBJECT IDENTIFIER ::= { sys 2 }

timezone OBJECT-TYPE
SYNTAX INTEGER
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: the timezone in which the unit has to operate (GMT +- nbr of seconds +- nbr of seconds DLS)
 "
::= {time 1}

ntp-server-ip-str OBJECT-TYPE
SYNTAX DisplayString
ACCESS read-write
STATUS optional
DESCRIPTION 
"WRITE: sets the ntp server ip (as string; xxx.xxx.xxx.xxx or URL) to sync time from
 READ: reads the time servers ip address (xxx.xxx.xxx.xxx, or URL) used to sync time from
 "
::= {time 2}

time-sc-connect-fail-msg OBJECT-TYPE
SYNTAX INTEGER
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: neither read nor write access, only message, 1 = connect to server for time sync failed
 "
::= {time 3}



connection OBJECT IDENTIFIER ::= { sys 3 }

connect-to OBJECT-TYPE
SYNTAX OCTET STRING
ACCESS read-only
STATUS optional
DESCRIPTION 
"READ: See RCP docu for command CONF_CONNECT_TO
 "
::= {connection 1}

disconnect-primitive OBJECT-TYPE
SYNTAX OCTET STRING
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: NOT_SUPPORTED
 "
::= {connection 2}



viproc OBJECT IDENTIFIER ::= { sys 4 }


viprocTable OBJECT-TYPE
SYNTAX  SEQUENCE OF ViprocEntry
ACCESS  not-accessible
STATUS  mandatory
DESCRIPTION ""
::= { viproc 1 }

viprocEntry OBJECT-TYPE
SYNTAX  ViprocEntry
ACCESS  not-accessible
STATUS  mandatory
DESCRIPTION ""
INDEX   { viproc-id }
::= { viprocTable 1 }

viproc-id OBJECT-TYPE
SYNTAX INTEGER
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: get the viproc interface id (0:= no viproc), nb: message is sent in host byte order
 "
::= {viprocEntry 1}

viproc-mode OBJECT-TYPE
SYNTAX INTEGER
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: switches between silent vca(0)/manual(1..16)/off(0xfd)/scheduler(0xfe)/script mode(0xff) of the video content analysis (VCA). In case of a moving dome and a preset with activated VCA profile the active Id is returned. (if vca is turned off then 0xfd is returned).
 "
::= {viprocEntry 2}

ViprocEntry ::= SEQUENCE {
viproc-id INTEGER,
viproc-mode INTEGER
}



aux OBJECT IDENTIFIER ::= { sys 5 }

oem-device-name OBJECT-TYPE
SYNTAX DisplayString
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: get the oem device name
 "
::= {aux 1}

oem-ext-id OBJECT-TYPE
SYNTAX INTEGER
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: DEPRECATED: please use CONF_DEVICE_TYPE_IDS instead. Get the oem extension id
 "
::= {aux 2}

defaults OBJECT-TYPE
SYNTAX INTEGER
ACCESS write-only
STATUS optional
DESCRIPTION 
"WRITE: sets config to default values except IP, subnet and gateway and resets the device. ATTENTION: Wait till board has fully rebooted before switching of power, to ensure that defaults are applied completly. Also propagade this to the user, that he has to wait until the reboot is complete.
 "
::= {aux 3}

factory-defaults OBJECT-TYPE
SYNTAX INTEGER
ACCESS write-only
STATUS optional
DESCRIPTION 
"WRITE: set the configuration to factory defaults and reset the board. ATTENTION: Wait till board has fully rebooted before switching of power, to ensure that defaults are applied completly. Also propagade this to the user, that he has to wait until the reboot is complete.
 "
::= {aux 4}

board-reset OBJECT-TYPE
SYNTAX INTEGER
ACCESS write-only
STATUS optional
DESCRIPTION 
"WRITE: reset the board
 "
::= {aux 5}

boot-default-app OBJECT-TYPE
SYNTAX INTEGER
ACCESS write-only
STATUS optional
DESCRIPTION 
"WRITE: boot the default application
 "
::= {aux 6}

led-blinking OBJECT-TYPE
SYNTAX INTEGER
ACCESS read-write
STATUS optional
DESCRIPTION 
"WRITE: 1=power LED will flash for 7 sec
 READ: always 1
 "
::= {aux 7}


bsp-dev-errorTable OBJECT-TYPE
