network OBJECT IDENTIFIER ::= { rcp 5 }



interface OBJECT IDENTIFIER ::= { network 1 }

mac-address OBJECT-TYPE
SYNTAX OCTET STRING
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: read out the systems MAC address.##Num Values: 1=Ethernet; 2=WLAN; 3=Bluetooth
 "
::= {interface 1}

ip-str OBJECT-TYPE
SYNTAX DisplayString
ACCESS read-write
STATUS optional
DESCRIPTION 
"WRITE: Set the unit's IP address using string notation (xxx.xxx.xxx.xxx)
 READ: Read the unit's IP address using string notation (xxx.xxx.xxx.xxx)##Num Values: 0=Default; 1=Primary IP; 2=Auto IP (read direction)
 "
::= {interface 2}

subnet-str OBJECT-TYPE
SYNTAX DisplayString
ACCESS read-write
STATUS optional
DESCRIPTION 
"WRITE: set the subnet mask using string notation (xxx.xxx.xxx.xxx)
 READ: Read the subnet mask using string notation (xxx.xxx.xxx.xxx)##Num Values: 0=Default; 1=Primary IP Subnet; 2=Auto IP Subnet (read direction)
 "
::= {interface 3}

gateway-ip-str OBJECT-TYPE
SYNTAX DisplayString
ACCESS read-write
STATUS optional
DESCRIPTION 
"WRITE: set the gateway IP using string notation (xxx.xxx.xxx.xxx)
 READ: read the gateway IP using string notation (xxx.xxx.xxx.xxx)
 "
::= {interface 4}

dhcp-val OBJECT-TYPE
SYNTAX INTEGER
ACCESS read-write
STATUS optional
DESCRIPTION 
"WRITE: set DHCP mode
 READ: read DHCP mode ##Valuelist: 0=OFF; 1=ON (On write: Enables DHCP and kicks lease acquisition mechanism); 2=ON No Kick (Write only: enables DHCP mode in config, but does not kick lease acquisition mechanism); 3=ON+APIPA-Fallback
 "
::= {interface 5}

eth-link OBJECT-TYPE
SYNTAX INTEGER
ACCESS read-write
STATUS optional
DESCRIPTION 
"WRITE: (half duplex=HD, full duplex =FD) 0=auto, 1=10MbitHD, 2=10MbitFD, 3=100MbitHD, 4=100MbitFD, 5=1000MbitFD, 8=10GbitFD
 READ: (half duplex=HD, full duplex =FD) 0=auto, 1=10MbitHD, 2=10MbitFD, 3=100MbitHD, 4=100MbitFD
 "
::= {interface 6}

enable-traffic-led OBJECT-TYPE
SYNTAX INTEGER
ACCESS read-write
STATUS optional
DESCRIPTION 
"WRITE: Enables or disables the network activity LED (Dinion, NBC-255 camera)
 READ: network activity LED (Dinion, NBC-255 camera): 0=off; 1=on; 2=off 10 minutes after startup
 "
::= {interface 7}


eth-link-statusTable OBJECT-TYPE
SYNTAX  SEQUENCE OF Eth-link-statusEntry
ACCESS  not-accessible
STATUS  mandatory
DESCRIPTION ""
::= { interface 8 }

eth-link-statusEntry OBJECT-TYPE
SYNTAX  Eth-link-statusEntry
ACCESS  not-accessible
STATUS  mandatory
DESCRIPTION ""
INDEX   { eth-link-status }
::= { eth-link-statusTable 1 }

eth-link-status OBJECT-TYPE
SYNTAX INTEGER
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: (half duplex=HD, full duplex =FD) 0=No link, 1=10MbitHD, 2=10MbitFD, 3=100MbitHD, 4=100MbitFD, 5=1000MbitFD, 7=Wlan; 8=10GbitFD
 "
::= {eth-link-statusEntry 1}

Eth-link-statusEntry ::= SEQUENCE {
eth-link-status INTEGER
}


