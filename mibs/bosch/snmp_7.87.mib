::= {inputEntry 1}

InputEntry ::= SEQUENCE {
input-source-val INTEGER
}


encoderTable OBJECT-TYPE
SYNTAX  SEQUENCE OF EncoderEntry
ACCESS  not-accessible
STATUS  mandatory
DESCRIPTION ""
::= { video 2 }

encoderEntry OBJECT-TYPE
SYNTAX  EncoderEntry
ACCESS  not-accessible
STATUS  mandatory
DESCRIPTION ""
INDEX   { video-encoder-status-ext }
::= { encoderTable 1 }

video-encoder-status-ext OBJECT-TYPE
SYNTAX OCTET STRING
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: get encoder status (20 bytes) 1st DWORD: 10*frames per sec, 2nd DWORD: KBPS, 3rd DWORD: grab frame fps*10, 4th lost frame fps*10 due to overload, 5th DWORD skipped frame fps*10 due to configured enc interval in profile or STREAM_PRIORITY
 "
::= {encoderEntry 1}

video-encoder-encoded-bytes OBJECT-TYPE
SYNTAX INTEGER
ACCESS read-only
STATUS optional
DESCRIPTION 
" READ: Get encoded bytes (32 Bit Counter) since bootup. Only supported for h.264 and Jpeg encoder.
 "
::= {encoderEntry 2}

EncoderEntry ::= SEQUENCE {
video-encoder-status-ext OCTET STRING,
video-encoder-encoded-bytes INTEGER
}



