BOSCH DEFINITIONS ::= BEGIN

IMPORTS
   enterprises, Integer32                               FROM SNMPv2-SMI
   MODULE-IDENTITY, OBJECT-TYPE, NOTIFICATION-TYPE      FROM SNMPv2-SMI
   DisplayString                                        FROM SNMPv2-TC
   OBJECT-GROUP, NOTIFICATION-GROUP, MODULE-COMPLIANCE  FROM SNMPv2-CONF;

bvms MODULE-IDENTITY
LAST-UPDATED "202310190000Z"
ORGANIZATION "Bosch Sicherheitssysteme GmbH 2005-2023"
CONTACT-INFO
"This is how you can reach us: phone: +49 (0)711 400 40990, fax: +49 (0)711 400 40999, post address: Robert Bosch GmbH, Bosch Service Center, Postfach 30 02 20, 70442 Stuttgart, GERMANY"
DESCRIPTION
"The MIB module for BVMS entities. Copyright (C) Bosch Sicherheitssysteme GmbH 2005-2023."
REVISION "202310190000Z"
DESCRIPTION
"Re-added category 'BRS/DiBos Devices' and marked the corresponding devices/states/events/traps as obsolete."
REVISION "202310180000Z"
DESCRIPTION
"Marked device types 'NVR Server' and 'Vidos NVR Device' and the associated states/events/traps as obsolete."
REVISION "202203090000Z"
DESCRIPTION
"Added Threat Level devices and its state."
REVISION "202008200000Z"
DESCRIPTION
"Added RecordingMonitorState and SecondaryRecordingMonitorState event."
REVISION "202008060000Z"
DESCRIPTION
"Added TimeSynchronizationFailed and SdCardLifespanStatus event."
REVISION "202003260000Z"
DESCRIPTION
"Added Trs operation state event."
REVISION "202001210000Z"
DESCRIPTION
"Added audio alarm event."
REVISION "201912110000Z"
DESCRIPTION
"Added user account disabled event."
REVISION "201910080000Z"
DESCRIPTION
"Added access controller relay and input devices and states."
REVISION "201910030000Z"
DESCRIPTION
"Added Lpr subsystem state."
REVISION "201909240000Z"
DESCRIPTION
"Added access door device and events."
REVISION "201908220000Z"
DESCRIPTION
"Added 3 more access reader events (denied screening required, granted did not enter, duress event)."
REVISION "201905230000Z"
DESCRIPTION
"Added SignalTooBlurry and GlobalChange event."
REVISION "201905080000Z"
DESCRIPTION
"Added ONVIF video analysis states."
REVISION "201904040000Z"
DESCRIPTION
"Added TRS Error event."
REVISION "201904020000Z"
DESCRIPTION
"Added user action event logbook-data erased."
REVISION "201903260000Z"
DESCRIPTION
"Added user action events Subject-Added/Updated/Removed/Renamed. (A 'subject' is a person in the context of face-recognition.)"
REVISION "201812010000Z"
DESCRIPTION
"Added FaceRecognition event."
REVISION "201807040000Z"
DESCRIPTION
"Made this MIB module more compliant with standards."
REVISION "201803230000Z"
DESCRIPTION
"Added user action events (UserActionAccessGranted, UserActionAccessDenied)"
REVISION "201802050000Z"
DESCRIPTION
"Added access device and events"
REVISION "201712110000Z"
DESCRIPTION
"Added task activity monitor events ('BVMS tasks')"
REVISION "201701160000Z"
DESCRIPTION
"Fixed index numbers on Camera Visibility events"
REVISION "201701120000Z"
DESCRIPTION
"Added CameraVisibility to Allegiant, Dibos, DVR and ONVIF camera types"
REVISION "201612300000Z"
DESCRIPTION
"Added VcsDevice event (Visibility)."
REVISION "201605310000Z"
DESCRIPTION
"Added user action events (Restrict/Unrestrict)."
REVISION "201602260000Z"
DESCRIPTION
"Added FireOrSmoke (VcsDevice)."
REVISION "201602240000Z"
DESCRIPTION
"Added VideoAuthenticityChecked event."
REVISION "201602120000Z"
DESCRIPTION
"Added 3 Onvif peak events (OnvifGenericEvent)."
REVISION "201601280000Z"
DESCRIPTION
"Added ExternalData event."
REVISION "201509290000Z"
DESCRIPTION
"Added user action events (PointBypassed, PointUnbypassed)."
REVISION "201509281003Z"
DESCRIPTION
"Added Onvif state events (SignalPresence, SignalTooBright-Dark-Noisy, Adjustment)."
REVISION "201508280000Z"
DESCRIPTION
"Added user action events (DoorLocked, DoorUnlocked, DoorSecured, DoorUnsecured, DoorCycled)."
REVISION "201508250000Z"
DESCRIPTION
"Added IntrusionPanel door and events."
REVISION "201505210000Z"
DESCRIPTION
"Added IntrusionPanel output and events."
REVISION "201505150000Z"
DESCRIPTION
"Added user action events (AreaBellsSilenced)."
REVISION "201501220000Z"
DESCRIPTION
"Added user action events (AreaArmed, AreaDisarmed, AreaForceArmed)."
REVISION "201409170000Z"
DESCRIPTION
"Added IntrusionPanel device and events."
REVISION "201401130000Z"
DESCRIPTION
"The initial revision of BVMS MIB module."
::= { enterprises bosch(5318) boschBvms(2505) 1 }

