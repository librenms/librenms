
ENGENIUS-PRIVATE-MIB-ECW-SECRIAL-AP DEFINITIONS ::= BEGIN

IMPORTS
	MODULE-IDENTITY, OBJECT-TYPE, NOTIFICATION-TYPE, OBJECT-IDENTITY, 
	enterprises, snmpModules, IpAddress, Counter32, Gauge32, TimeTicks, Integer32,
	Counter64                                              
            	FROM SNMPv2-SMI
                                                   
	DisplayString, MacAddress, TruthValue, TimeStamp,
	TimeInterval, DateAndTime, RowStatus, TEXTUAL-CONVENTION
				FROM SNMPv2-TC

	MODULE-COMPLIANCE, OBJECT-GROUP, NOTIFICATION-GROUP
				FROM SNMPv2-CONF

	ifIndex
				FROM RFC1213-MIB
        
	InetAddressType, InetAddress 
				FROM INET-ADDRESS-MIB;    
		  
engeniusprivate MODULE-IDENTITY
    LAST-UPDATED "202212151007Z"
    ORGANIZATION "R&D Dept., S/W Division"
    CONTACT-INFO
       "
       "
   DESCRIPTION
       "
       "
    REVISION        "200906111100Z"
    DESCRIPTION	    "Added new parameter: modelname,rf power, macadd, rssi"
    REVISION        "200906101600Z"
    DESCRIPTION	    "Simplified version, remove unsupported item, added ipaddress type, added reboot cmd"
    REVISION        "200905141000Z"
    DESCRIPTION	    "First version of Engenius-Private-MIB"
    REVISION        "201111171030Z"
    DESCRIPTION	    "v1.0.8.2 of Engenius-Private-MIB"
    REVISION        "201112131030Z"
    DESCRIPTION	    "v1.0.9 of Engenius-Private-MIB"
    REVISION        "201312131642Z"
    DESCRIPTION	    "v2.0.0 of Engenius-Private-MIB"
   ::= { engenius 9 }

engenius				OBJECT IDENTIFIER ::= { enterprises 14125 }

sys			OBJECT IDENTIFIER ::= { engeniusprivate 1 }
    sys_info			        OBJECT IDENTIFIER ::= { sys 1 }
    --login                       OBJECT IDENTIFIER ::= { sys 2 }
    snmp                        OBJECT IDENTIFIER ::= { sys 3 }


net		OBJECT IDENTIFIER ::= { engeniusprivate 2 }
    ethernet				OBJECT IDENTIFIER ::= { net 1 }
        ipv4            OBJECT IDENTIFIER ::= { ethernet 2 }
        ipv6            OBJECT IDENTIFIER ::= { ethernet 3 }
    stp				OBJECT IDENTIFIER ::= { net 2 }

--ntp				OBJECT IDENTIFIER ::= { configuration 6 }

wifi		OBJECT IDENTIFIER ::= { engeniusprivate 3 }
    radio       OBJECT IDENTIFIER ::= { wifi 1 }
	    twoG	OBJECT IDENTIFIER ::= { radio 1 }
        fiveG              OBJECT IDENTIFIER ::= { radio 2 }
    ssid        OBJECT IDENTIFIER ::= { wifi 2 }
        wireless_security   OBJECT IDENTIFIER ::= { ssid 4 }
        schedule            OBJECT IDENTIFIER ::= { ssid 7 }
        

    client_info OBJECT IDENTIFIER ::= { wifi 3 }
        client_24g            OBJECT IDENTIFIER ::={ client_info 1 }
        client_5g              OBJECT IDENTIFIER ::={ client_info 2 }

snmpMIB                 OBJECT IDENTIFIER ::= { snmpModules 1 }
    snmpMIBObjects          OBJECT IDENTIFIER ::= { snmpMIB 1 }
        snmpTraps                OBJECT IDENTIFIER ::= { snmpMIBObjects 5 }


-- ==========================
-- Defination Begins
-- ==========================

-- =======| status > system | ===============

firmware_version OBJECT-TYPE
	  SYNTAX DisplayString (SIZE (0..256))
	  MAX-ACCESS read-only
	  STATUS current
	  DESCRIPTION
	  "Firmware model name"
     ::= { sys_info 1 }	


serial_number OBJECT-TYPE
	   SYNTAX DisplayString
	   MAX-ACCESS read-only
	   STATUS current
	   DESCRIPTION
	   ""
	   ::={ sys_info 2 }

uptime OBJECT-TYPE
	   SYNTAX DisplayString
	   MAX-ACCESS read-only
	   STATUS current
	   DESCRIPTION
	   ""
      ::={ sys_info 3 }	 

device_name OBJECT-TYPE
	SYNTAX DisplayString (SIZE (0..32))
  	MAX-ACCESS read-only
     	STATUS current
     	DESCRIPTION
	"The DUT's device name."
	DEFVAL { "EnGenius SERIAL AP" }
     ::= { sys_info 4 }

mac_address OBJECT-TYPE
	   SYNTAX DisplayString (SIZE(0..17))
	   MAX-ACCESS read-only
	   STATUS current
	   DESCRIPTION
	   "The wireless MAC address"
      ::={ sys_info 5 }

mac_24g_address OBJECT-TYPE
	   SYNTAX DisplayString (SIZE(0..17))
	   MAX-ACCESS read-only
	   STATUS current
	   DESCRIPTION
	   "The wireless 2_4G MAC address"
      ::={ sys_info 6 }

mac_5g_address OBJECT-TYPE
	   SYNTAX DisplayString (SIZE(0..17))
	   MAX-ACCESS read-only
	   STATUS current
	   DESCRIPTION
	   "The wireless 5G MAC address"
      ::={ sys_info 7 }
      
mac_6g_address OBJECT-TYPE
	   SYNTAX DisplayString (SIZE(0..17))
	   MAX-ACCESS read-only
	   STATUS current
	   DESCRIPTION
	   "The wireless 6G MAC address"
      ::={ sys_info 8 }

-- login is for post. need to comfirm.

cpu_loading OBJECT-TYPE
	   SYNTAX DisplayString
	   MAX-ACCESS read-only
	   STATUS current
	   DESCRIPTION
	   ""
	   ::={ sys_info 9 }

mem_usage OBJECT-TYPE
	   SYNTAX DisplayString
	   MAX-ACCESS read-only
	   STATUS current
	   DESCRIPTION
	   ""
	   ::={ sys_info 10 }

-- =======| configuration > ntp | ===============

timezone OBJECT-TYPE
	SYNTAX DisplayString (SIZE (0..128))
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"To setting time zone in DUT:
		zone name (timezone)
		UTC-12:00 Kwajalein (UTC12), 
		UTC-11:00 Midway-Island, Samoa (UTC11),
		UTC-10:00 Hawaii (UTC10),
		UTC-09:00 Alaska (NAST9),
		UTC-08:00 Pacific-Time (PST8),
		UTC-07:00 Arizona (UTC7),  
		UTC-07:00 Mountain-Time (MST7),
		UTC-06:00 Mexico (UTC6),
		UTC-06:00 Central-Time (CST6),
		UTC-05:00 Colombia, Panama (UTC5),
		UTC-05:00 Eastern-Time (EST5),
		UTC-04:00 Bolivia, Venezuela (UTC4),
		UTC-04:00 Atlantic-Time (AST4),
		UTC-04:00 Brazil-West (BRWST4),
		UTC-03:30 Newfoundland (NST3:30),
		UTC-03:00 Greenland (WGST3),
		UTC-03:00 Brazil-East (BRST3),
		UTC-03:00 Guyana (UTC3),
		UTC-02:00 Mid-Atlantic (UTC2),
		UTC-01:00 Azores (STD1),
		UTC+00:00 Gambia, Liberia, Morocco (UTC0),
		UTC+00:00 England (GMT0),
		UTC+01:00 Tunisia (UTC-1),
		UTC+01:00 France, Germany, Italy (STD-1),
		UTC+02:00 South-Africa (UTC-2),
		UTC+02:00 Greece, Ukraine, Romania, Turkey (STD-2),
		UTC+03:00 Iraq, Jordan, Kuwait (UTC-3),
		UTC+03:00 Finland (EEST-3),
		UTC+04:00 Armenia (UTC-4),
		UTC+05:00 Pakistan, Russia (UTC-5),
		UTC+05:30 Bombay, Calcutta, Madras, New-Delhi (UTC-5:30),
		UTC+06:00 Bangladesh, Russia (UTC-6), 
		UTC+07:00 Thailand, Russia (UTC-7), 
		UTC+08:00 China, Hong-Kong, Western-Australia, Singapore, Taiwan, Russia (UTC-8),
		UTC+09:00 Japan, Korea (UTC-9),
		UTC+09:30 South-Australia (CST-9:30),
		UTC+10:00 Guam, Russia (UTC-10),
		UTC+10:00 Australia (STD-10),
		UTC+11:00 Solomon-Islands (UTC-11),
		UTC+12:00 Fiji (UTC-12),
		UTC+12:00 New-Zealand (NZST-12)"
	DEFVAL { "GMT0" }
     ::= { sys_info 11 }

-- ============== Time Zone END ===========================



-- =======| configuration > snmp | ===============

enable OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"Enable / Disable SNMP agent"
	DEFVAL { Enable }
	::= { snmp 1 }

community OBJECT-TYPE
	SYNTAX DisplayString (SIZE(0..33))
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"The communication string for Read Only"
	DEFVAL { public }
	::= { snmp 2 }

-- ============== END ===========================

-- =======| net > ethernet | ===============

mode OBJECT-TYPE
	SYNTAX DisplayString
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
    "IP Network Setting"
    DEFVAL { "DHCP" }
    ::= { ethernet 1 }

ip OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"To setting static LAN IP address in DUT"
	DEFVAL { "192.168.1.1" }
     ::= { ipv4 1 }

mask OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"To setting static Subnet Mask in DUT"
	DEFVAL { "255.255.255.0" }
     ::= { ipv4 2 }

gateway OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"To setting getway IP address in DUT"
	DEFVAL { "0.0.0.0" }
     ::= { ipv4 3 }

primary_dns OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"To setting Primary DNS IP address in DUT"
	DEFVAL { "0.0.0.0" }
     ::= { ipv4 4 }
	 
secondary_dns OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"To setting SecondaryDNS IP address in DUT"
	DEFVAL { "0.0.0.0" }
     ::= { ipv4 5 }

linkLocal OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	""
	DEFVAL { "true" }
     ::= { ipv6 1 }

ip OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"To setting static Ipv6 address in DUT"
	--DEFVAL { "255.255.255.0" }
     ::= { ipv6 2 }

prefix OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"To setting IPv6 prefix in DUT"
	DEFVAL { "0" }
     ::= { ipv6 3 }

gateway OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"To setting IPv6 gateway IP address in DUT"
	--DEFVAL { "0.0.0.0" }
     ::= { ipv6 4 }
	 
primary_dns OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"To setting IPv6 Primary DNS IP address in DUT"
	-- DEFVAL { "0.0.0.0" }
     ::= { ipv6 5 }

secondary_dns OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"To setting IPv6 Secondary DNS IP address in DUT"
	-- DEFVAL { "0.0.0.0" }
     ::= { ipv6 6 }
	 
-- ============== END ================================

-- =======| net > stp | ===============

mgmt_vlanid OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
    "Dispaly Management VLAN ID"
    ::= { ethernet 4 }

mode OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"Enable / Disable Spanning Tree"
	DEFVAL { Disable }
	::= { stp 1 }

priority OBJECT-TYPE
	SYNTAX Integer32 (0..65535)
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"The manageable component of the Port Identifier. IEEE 802.1D 17.13.10.
    Minimum: 0. Maximum: 65535."
	DEFVAL { 32768 }
	::= { stp 2 }

-- ============== END ===========================

-- =======| wifi > radio > 24g | ===============

enable OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
    "Enable/ Disable 2_4G wireless lan band"
    ::= { twoG 1 }

country OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"The country name. 
	The supported country ID as follows,
	FCC : {0,3,11,12,14,15,19,20,27,29,45,46,54,55,59,71,81,83}
	ETSI : {0,1,5,7,10,16,17,18,22,23,24,25,26,30,31,34,37,43,47,49,50,57,58,61,62,64,65,67,69,70,77,78,79}
	INT : all
        na (0),
		albania (1),
		algeria (2),
		argentina (3),
		australia (4),
		austria (5),
		bahrain (6),
		belgium (7),
		brazil (8),
		brunei (9),
		bulgaria (10),
		canada (11),
		chile (12),
