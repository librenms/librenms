    ::= { bandwidth_limit_table 1 }

bandwidth_limitEntry ::=
SEQUENCE
{
    enable                      DisplayString,
    ssid_download_limit         Integer32,
    ssid_upload_limit           Integer32,
    perclient_download_limit    Integer32,
    perclient_upload_limit      Integer32
}

