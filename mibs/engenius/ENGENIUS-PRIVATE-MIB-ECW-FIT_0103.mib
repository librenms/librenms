		uruguay (81),
		usa (82),
		uzbekistan (83),
		venezuela (84),
		vietnam (85)"
	DEFVAL { na }
     ::= { twoG 2 }


hw_mode OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"The wireless lan operation mode. 
    {11b, 11g, 11bg, 11n, 11ng, 11axg}"
	DEFVAL { bgn_Mixed}
	::= { twoG 3 }

is_11ax_disable OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
    "Eblae / Disable 11ax mode"
    ::= { twoG 4 }

channel OBJECT-TYPE
	SYNTAX Integer32 (0..13)
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"The wireless 2.4G channel frequency. Minimum: 0. Maximum: 14. 0 is auto"
     ::= { twoG 5 }


ht_mode OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"The WLAN narrow band
    {HT20, HT20_40, HT40}"
	::= { twoG 6 }


tx_power OBJECT-TYPE
	SYNTAX Integer32 (8..28)
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"The WLAN transmission power. Minimum: 8. Maximum: 28. 0 is auto" 
        ::= { twoG 7 }

--clientlimit2point4GEnable OBJECT-TYPE
	--SYNTAX DisplayString
    --MAX-ACCESS read-only
    --STATUS current
    --DESCRIPTION
    --"Enable / Disable client limit function"
    --DEFVAL { Enable }
    --::= { clientLimit 1 }

client_limit OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"Max number of client"
    ::= { twoG 8 }

--clientlimit5GEnable OBJECT-TYPE
	--SYNTAX DisplayString
    --MAX-ACCESS read-only
    --STATUS current
    --DESCRIPTION
    --"Enable / Disable client limit function"
    --DEFVAL { Enable }
    --::= { clientLimit 3 }


min_bitrate OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
    "The WLAN minimum bit rate"
    ::= { twoG 9 }

opmode OBJECT-TYPE
	SYNTAX DisplayString
	MAX-ACCESS read-only
	STATUS current
	DESCRIPTION
	"The WLAN operation mode.
    {ap, wds_ap, wds_bridge, wds_sta, sta_ap, sta}"
	DEFVAL { ap }
	::= { twoG 10 }

legacy_hwmode_deny OBJECT-TYPE
    SYNTAX DisplayString
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
    ""
    ::= { twoG 11 }

channel_list OBJECT-TYPE	
    SYNTAX DisplayString
   	MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
	"Show channel list that control by CountryCode."
	::= { twoG 20 }


