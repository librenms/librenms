-- =======| wifi > client_info ================================

client_number OBJECT-TYPE
    SYNTAX Integer32 (0..65535)
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
	"The number of connected clients"
    ::= { client_24g 1 }


client_list OBJECT-TYPE
	   SYNTAX DisplayString
	   MAX-ACCESS read-only
	   STATUS current
	   DESCRIPTION
	   "The 2.4G wireless client list."
      ::={ client_24g 2 }


client_info_24g_table OBJECT-TYPE
    	SYNTAX SEQUENCE OF LiveClientTableEntry
    	MAX-ACCESS not-accessible
    	STATUS current
    	DESCRIPTION
	"This table display the list of client that associated to the device." 
    ::= { client_24g 3 }

client_info_24g_entry OBJECT-TYPE
    	SYNTAX LiveClientTableEntry
   	MAX-ACCESS not-accessible
    	STATUS current
    	DESCRIPTION
	"Represent the entry in the Client table."
    INDEX { ip_address }
    ::= { client_info_24g_table 1 }

LiveClientTableEntry::=
    SEQUENCE
    {
	mac_address 			DisplayString, 
	ip_address			DisplayString,
	host_name			DisplayString,
	tx_byte			Integer32,
	rx_byte			Integer32,
	os				DisplayString,
	rssi				DisplayString
    }

mac_address OBJECT-TYPE
    SYNTAX DisplayString (SIZE(0..17))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
	"The mac address of the client"
    ::= { client_info_24g_entry 1 }

ip_address OBJECT-TYPE
    SYNTAX DisplayString 
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
	"The IP address of the client"
    ::= { client_info_24g_entry 2 }

host_name OBJECT-TYPE
    SYNTAX DisplayString (SIZE(0..32))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
	"The hostname of the client"
    ::= { client_info_24g_entry 3 }

tx_byte OBJECT-TYPE
    SYNTAX Integer32 (0..65535)
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
	"The transmitted data bytes of the client, in Bytes"
    ::= { client_info_24g_entry 4}

rx_byte OBJECT-TYPE
    SYNTAX Integer32 (0..65535)
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
	"The received data bytes of the client, in Bytes"
    ::= { client_info_24g_entry 5 }
	
os OBJECT-TYPE
    SYNTAX DisplayString (SIZE(0..32))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
	"The OS of client"
    ::= { client_info_24g_entry 6 }
	
rssi OBJECT-TYPE
    SYNTAX DisplayString (SIZE(0..32))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
	"The connection RSSI of client"
    ::= { client_info_24g_entry 7 }
	 
