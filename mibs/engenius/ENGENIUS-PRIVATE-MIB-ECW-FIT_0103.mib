		israel (36),
		italy (37),
		japan (38),
		jordan (39),
		south-Korea (40),
		kuwait (41),
		lebanon (42),
		luxembourg (43),
		macau (44),
		malaysia (45),
		mexico (46),
		monaco (47),
		nepal (48),
		netherlands (49),
		norway (50),
		new-Zealand (51),
		oman (52),
		pakistan (53),
		panama (54),
		peru (55),
		philippines (56),
		poland (57),
		portugal (58),
		puerto-Rico (59),
		qatar (60),
		romania (61),
		russia (62),
		saudi-Arabia (63),
		singapore (64),
		slovakia (65),
